<%- include('../partials/head') %>

<h1>Weekly Settlement</h1>
<div class="meta">Enter earnings once — the app calculates the net payout automatically</div>

<div class="panel">
  <div class="panel-head"><h3>New Settlement</h3></div>
  <form method="POST" action="/settlements">
    <div class="form-grid">
      <div class="field">
        <label>Driver</label>
        <select name="driverId" required>
          <% drivers.forEach(d => { %>
            <option value="<%= d.id %>"><%= d.name %> <%= d.currentCar ? '(' + d.currentCar.plate + ')' : '' %></option>
          <% }) %>
        </select>
      </div>
      <div class="field"><label>Week Start</label><input type="date" name="weekStart" required></div>
      <div class="field"><label>Week End</label><input type="date" name="weekEnd" required></div>
      <div class="field"><label>Uber Earnings</label><input type="number" step="0.01" name="uberGross" value="0"></div>
      <div class="field"><label>Bolt Earnings</label><input type="number" step="0.01" name="boltGross" value="0"></div>
      <div class="field"><label>Fleet Charge (rental)</label><input type="number" step="0.01" name="fleetCharge" value="0"></div>
      <div class="field"><label>Fuel / Electric Bill</label><input type="number" step="0.01" name="fuelElectricCost" value="0"></div>
      <div class="field"><label>Via Verde</label><input type="number" step="0.01" name="viaVerde" value="0"></div>
      <div class="field"><label>Other Deductions</label><input type="number" step="0.01" name="otherDeductions" value="0"></div>
    </div>
    <div class="form-actions">
      <button class="btn" type="submit">Calculate & Save</button>
    </div>
    <p style="padding:0 16px 16px; color:var(--muted); font-size:12.5px;">
      Net = Gross (Uber+Bolt) − Fleet Charge − IVA (6% of gross, withheld) − Fuel/Electric − Via Verde − Other.
      The 6% IVA is tracked separately under IVA Refunds until the driver issues a green receipt.
    </p>
  </form>
</div>

<div class="panel">
  <div class="panel-head"><h3>Settlement History</h3></div>
  <form method="GET" action="/settlements" class="form-grid" style="padding:14px 16px 0;">
    <div class="field"><label>From (week start)</label><input type="date" name="from" value="<%= from %>"></div>
    <div class="field"><label>To (week start)</label><input type="date" name="to" value="<%= to %>"></div>
    <div class="field" style="align-self:flex-end;">
      <button class="btn" type="submit">Filter</button>
      <% if (from || to) { %> <a class="btn secondary" href="/settlements">Clear</a> <% } %>
    </div>
  </form>
  <table>
    <tr><th>Driver</th><th>Week</th><th>Gross</th><th>Fleet Charge</th><th>IVA</th><th>Fuel/Elec</th><th>Via Verde</th><th>Net Paid</th><th>Status</th><th></th></tr>
    <% settlements.forEach(s => { %>
      <tr>
        <td><%= s.driver.name %></td>
        <td><%= s.weekStart.toISOString().slice(0,10) %></td>
        <td>€<%= (s.uberGross + s.boltGross).toFixed(2) %></td>
        <td>€<%= s.fleetCharge.toFixed(2) %></td>
        <td>€<%= s.ivaWithheld.toFixed(2) %></td>
        <td>€<%= s.fuelElectricCost.toFixed(2) %></td>
        <td>€<%= s.viaVerde.toFixed(2) %></td>
        <td><b>€<%= s.netPaid.toFixed(2) %></b></td>
        <td><span class="badge <%= s.status === 'PAID' ? 'ok' : 'warn' %>"><%= s.status %></span></td>
        <td>
          <% if (s.status === 'PENDING') { %>
            <form class="inline-form" method="POST" action="/settlements/<%= s.id %>/pay">
              <button class="btn" type="submit">Mark Paid</button>
            </form>
          <% } %>
          <a class="btn secondary" href="/export/pdf/<%= s.id %>">PDF</a>
        </td>
      </tr>
    <% }) %>
  </table>
</div>

<%- include('../partials/foot') %>
