<%- include('../partials/head') %>

<h1>Maintenance Log</h1>

<div class="panel">
  <div class="panel-head"><h3>Add Entry</h3></div>
  <form method="POST" action="/maintenance">
    <div class="form-grid">
      <div class="field">
        <label>Car</label>
        <select name="carId" required>
          <% cars.forEach(c => { %><option value="<%= c.id %>"><%= c.plate %></option><% }) %>
        </select>
      </div>
      <div class="field"><label>Date</label><input type="date" name="date"></div>
      <div class="field"><label>Description</label><input name="description" required></div>
      <div class="field"><label>Cost</label><input type="number" step="0.01" name="cost" required></div>
      <div class="field"><label>Garage</label><input name="garage"></div>
      <div class="field"><label>Next Service Due</label><input type="date" name="nextServiceDue"></div>
    </div>
    <div class="form-actions"><button class="btn" type="submit">Save Entry</button></div>
  </form>
</div>

<div class="panel">
  <table>
    <tr><th>Car</th><th>Date</th><th>Description</th><th>Cost</th><th>Garage</th><th>Next Service</th><th></th></tr>
    <% logs.forEach(m => { %>
      <tr>
        <td><%= m.car.plate %></td>
        <td><%= m.date.toISOString().slice(0,10) %></td>
        <td><%= m.description %></td>
        <td>€<%= m.cost.toFixed(2) %></td>
        <td><%= m.garage || '-' %></td>
        <td><%= m.nextServiceDue ? m.nextServiceDue.toISOString().slice(0,10) : '-' %></td>
        <td>
          <form class="inline-form" method="POST" action="/maintenance/<%= m.id %>?_method=DELETE" onsubmit="return confirm('Delete this entry?');">
            <button class="btn danger" type="submit">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </table>
</div>

<%- include('../partials/foot') %>
