<%- include('../partials/head') %>

<h1>Custom Payments</h1>
<div class="meta">Extra income received outside the standard per-car fleet charge</div>

<div class="panel">
  <div class="panel-head"><h3>Add Custom Payment</h3></div>
  <form method="POST" action="/custom-payments">
    <div class="form-grid">
      <div class="field"><label>Payment Name</label><input name="name" required></div>
      <div class="field"><label>Amount</label><input type="number" step="0.01" name="amount" required></div>
      <div class="field"><label>Date</label><input type="date" name="date"></div>
      <div class="field"><label>Notes</label><input name="notes"></div>
    </div>
    <div class="form-actions"><button class="btn" type="submit">Save Payment</button></div>
  </form>
</div>

<div class="panel">
  <div class="panel-head"><h3>Payment History</h3></div>
  <form method="GET" action="/custom-payments" class="form-grid" style="padding:14px 16px 0;">
    <div class="field"><label>From</label><input type="date" name="from" value="<%= from %>"></div>
    <div class="field"><label>To</label><input type="date" name="to" value="<%= to %>"></div>
    <div class="field" style="align-self:flex-end;">
      <button class="btn" type="submit">Filter</button>
      <% if (from || to) { %> <a class="btn secondary" href="/custom-payments">Clear</a> <% } %>
    </div>
  </form>
  <table>
    <tr><th>Date</th><th>Name</th><th>Notes</th><th>Amount</th><th></th></tr>
    <% if (payments.length === 0) { %>
      <tr><td colspan="5" style="color:var(--muted);">No custom payments recorded<% if (from || to) { %> for this range<% } %>.</td></tr>
    <% } %>
    <% payments.forEach(p => { %>
      <tr>
        <td><%= p.date.toISOString().slice(0,10) %></td>
        <td><%= p.name %></td>
        <td><%= p.notes || '-' %></td>
        <td>€<%= p.amount.toFixed(2) %></td>
        <td>
          <form class="inline-form" method="POST" action="/custom-payments/<%= p.id %>?_method=DELETE" onsubmit="return confirm('Delete this payment?');">
            <button class="btn danger" type="submit">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
    <% if (payments.length > 0) { %>
      <tr><td colspan="3"><b>Total</b></td><td><b>€<%= total.toFixed(2) %></b></td><td></td></tr>
    <% } %>
  </table>
</div>

<%- include('../partials/foot') %>
