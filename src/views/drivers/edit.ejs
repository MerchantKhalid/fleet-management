<%- include('../partials/head') %>

<h1>Edit Driver</h1>

<div class="panel">
  <form method="POST" action="/drivers/<%= driver.id %>?_method=PUT">
    <div class="form-grid">
      <div class="field"><label>Name</label><input name="name" value="<%= driver.name %>" required></div>
      <div class="field"><label>Phone</label><input name="phone" value="<%= driver.phone || '' %>"></div>
      <div class="field"><label>NIF</label><input name="nif" value="<%= driver.nif || '' %>"></div>
      <div class="field"><label>TVDE License Number</label><input name="tvdeLicenseNumber" value="<%= driver.tvdeLicenseNumber || '' %>"></div>
      <div class="field"><label>TVDE Expiry</label><input type="date" name="tvdeExpiry" value="<%= driver.tvdeExpiry ? driver.tvdeExpiry.toISOString().slice(0,10) : '' %>"></div>
      <div class="field"><label>Driving License Expiry</label><input type="date" name="drivingLicenseExpiry" value="<%= driver.drivingLicenseExpiry ? driver.drivingLicenseExpiry.toISOString().slice(0,10) : '' %>"></div>
      <div class="field">
        <label>Status</label>
        <select name="status">
          <option value="ACTIVE" <%= driver.status === 'ACTIVE' ? 'selected' : '' %>>Active</option>
          <option value="INACTIVE" <%= driver.status === 'INACTIVE' ? 'selected' : '' %>>Inactive</option>
        </select>
      </div>
    </div>
    <div class="form-actions">
      <button class="btn" type="submit">Save Changes</button>
      <a class="btn secondary" href="/drivers">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/foot') %>
