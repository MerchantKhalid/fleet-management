<%- include('../partials/head') %>

<h1><%= driver.name %></h1>
<div class="meta"><span class="badge <%= driver.status === 'ACTIVE' ? 'ok' : 'danger' %>"><%= driver.status %></span></div>

<div class="panel">
  <div class="panel-head"><h3>Driver Details</h3></div>
  <table>
    <tr><th>Phone</th><td><%= driver.phone || '-' %></td></tr>
    <tr><th>Email</th><td><%= driver.email || '-' %></td></tr>
    <tr><th>IBAN</th><td><%= driver.iban || '-' %></td></tr>
    <tr><th>Car Ownership</th><td><%= driver.carOwnership === 'OWNED' ? 'Owned Car' : (driver.carOwnership === 'RENT' ? 'Rent' : '-') %></td></tr>
    <tr><th>Assigned Car</th><td><%= driver.currentCar ? driver.currentCar.plate : '-' %></td></tr>
  </table>
</div>

<div class="form-actions" style="margin-top:16px;">
  <a class="btn" href="/drivers/<%= driver.id %>/edit">Edit</a>
  <a class="btn secondary" href="/drivers">Back to Drivers</a>
</div>

<%- include('../partials/foot') %>
